# Next.js (`apps/web`) — never commit real secrets

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Прямое подключение Postgres для npm run db:migrate (Settings → Database → URI)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Базовый URL приложения: email confirm, OAuth, redirectTo.
# Production (Vercel): https://sonogyn-pro-web-ravshan-s-projects3.vercel.app (или ваш домен)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Локальный автовход (только npm run dev, NODE_ENV=development). В production/Vercel — не задавать.
DEV_AUTO_LOGIN=false
# Обход логина без Supabase (только local dev). Никогда не включать на Vercel/production.
DEV_SKIP_AUTH=false
DEV_LOGIN_EMAIL=you@example.com
DEV_LOGIN_PASSWORD=your-dev-password
DEV_LOGIN_FULL_NAME=Якубов Равшан Вахобжонович
DEV_LOGIN_SPECIALIZATION=Врач УЗИ
DEV_LOGIN_INSTITUTION=Учреждение

# Telegram Bot (Telegram Login Widget)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=sonogyn_bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=sonogyn_bot

# Секрет для server-to-server (chat-server → /api/auth/telegram/bot). ОБЯЗАТЕЛЬНО сменить в production.
SONOGYN_AUTH_INTERNAL_SECRET=

# OAuth client ids (основная настройка — Supabase Dashboard)
NEXT_PUBLIC_VK_CLIENT_ID=
NEXT_PUBLIC_YANDEX_CLIENT_ID=

STRIPE_SECRET_KEY=sk_live_or_test
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO_MONTHLY=price_...

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

NEXT_PUBLIC_SENTRY_DSN=

# Rate limiting (production, multi-instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# AUTH_RATE_LIMIT_RELAXED=true  # только временно на staging; не в production
# BOT_DETECTION_ENABLED=false   # по умолчанию включено (блок scrapers на /api/*)

# Настройка лимитов без деплоя (limit + window в секундах). Примеры:
# RATE_LIMIT_AUTH_SIGN_IN=20
# RATE_LIMIT_AUTH_SIGN_IN_WINDOW_SEC=900
# RATE_LIMIT_PATIENTS_SEARCH=120
# RATE_LIMIT_PATIENTS_SEARCH_WINDOW_SEC=60
# RATE_LIMIT_PATIENTS_SEARCH_PER_USER=60
# RATE_LIMIT_AI_ORADS=40
# RATE_LIMIT_AI_ORADS_BURST=5
# RATE_LIMIT_AI_ORADS_BURST_WINDOW_SEC=10
# Полный список: apps/web/lib/security/rate-limit-config.ts

# Server-only AI (O-RADS proxy — never EXPO_PUBLIC_*)
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_ORADS_MODEL=openai/gpt-4o-mini
