# Скопируйте в `apps/mobile/server/.env.local` (не коммитится)

PORT=3100
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES=7d
ADMIN_EMAIL=your-admin@example.com

# Telegram bot (mobile auth)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=sonogyn_bot
TELEGRAM_WEBHOOK_SECRET=dev-webhook-secret

# Прокси Supabase-сессии → Next.js API
WEB_API_BASE_URL=http://localhost:3000
SONOGYN_AUTH_INTERNAL_SECRET=dev-internal-auth-secret-change-me
