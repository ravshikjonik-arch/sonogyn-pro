{
  "name": "@repo/mobile",
  "version": "0.2.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --port 19001 --lan",
    "start:clear": "expo start --port 19001 --lan --clear",
    "eas-build-pre-install": "find \"${EAS_BUILD_WORKINGDIR:-../..}\" -name 'package-lock.json' -type f -delete 2>/dev/null || true",
    "eas-build-post-install": "node ./scripts/eas-prune-mobile-node-modules.js",
    "start:tunnel": "expo start --tunnel --port 19001",
    "start:tunnel:clean": "bash scripts/start-tunnel-clean.sh",
    "start:share": "expo start --tunnel --port 19001",
    "start:anywhere": "expo start --tunnel --port 19001",
    "kill:metro": "bash scripts/kill-expo-ports.sh",
    "share:android": "bash scripts/share-android-eas.sh",
    "android": "expo start --android --port 19001 --lan",
    "ios": "expo start --ios --port 19001 --lan",
    "web": "expo start --web --port 19001",
    "web:clean": "bash scripts/kill-expo-ports.sh && npx expo start --web --port 19001",
    "web:dev": "expo start --web --port 19001",
    "web:build": "expo export --platform web",
    "web:serve": "npx serve dist",
    "pwa:icons": "bash scripts/pwa-icons.sh",
    "check:i18n:ru": "node ./scripts/check-i18n-ru-base.js",
    "elastography:checksum": "node ./scripts/elastography-config-checksum.js assets/test-elastography-config.json --write",
    "check": "npx tsc --noEmit && npm run test:orads-pro && npm run test:elastography-limits",
    "test:elastography-limits": "node --import tsx ./src/modules/elastography/calculators/inputLimits.test.ts",
    "verify": "npm run check && npx expo-doctor && npm run web:build",
    "doctor": "npx expo-doctor",
    "test:orads-pro": "node --import tsx ./src/features/oradsPro/logic/oradsCalculator.test.ts",
    "chat-server": "cd server && npm install && npm start",
    "eas:login": "npx eas-cli login",
    "eas:init": "npx eas-cli init",
    "eas:android:preview": "../../node_modules/.bin/eas build --platform android --profile preview",
    "eas:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "eas:android:prod": "npx eas-cli build --platform android --profile production",
    "eas:ios:prod": "npx eas-cli build --platform ios --profile production",
    "eas:all:preview": "npx eas-cli build --platform all --profile preview",
    "eas:all:prod": "npx eas-cli build --platform all --profile production",
    "eas:update:preview": "CI=1 npx eas-cli update --channel preview --non-interactive",
    "eas:update:preview:android": "CI=1 npx eas-cli update --channel preview --platform android --non-interactive",
    "eas:update:production": "CI=1 npx eas-cli update --channel production --non-interactive",
    "eas:submit:ios": "npx eas-cli submit --platform ios --profile production",
    "eas:submit:android": "npx eas-cli submit --platform android --profile production",
    "version:pilot": "node ./scripts/set-pilot-version.js",
    "release:pilot:v0.1": "npm run version:pilot -- 0.1.0 && npm run eas:android:preview",
    "release:pilot:v0.2": "npm run version:pilot -- 0.2.0 && npm run eas:android:preview",
    "release:pilot:v0.3": "npm run version:pilot -- 0.3.0 && npm run eas:android:preview",
    "release:pilot:v0.4": "npm run version:pilot -- 0.4.0 && npm run eas:android:preview",
    "lint": "echo \"skip\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@firebase/auth": "1.13.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.13",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.14.14",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@repo/clinical-guidelines": "workspace:*",
    "@repo/clinical-3d": "workspace:*",
    "@repo/clinical-reference": "workspace:*",
    "@repo/medical-calculations": "workspace:*",
    "@repo/medvedev-reference": "workspace:*",
    "@repo/nosology": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/ui": "workspace:*",
    "@supabase/supabase-js": "^2.105.3",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.10",
    "expo-crypto": "~15.0.9",
    "expo-font": "~14.0.12",
    "expo-gl": "~16.0.10",
    "expo-image-picker": "~17.0.11",
    "expo-localization": "~17.0.9",
    "expo-linking": "~8.0.8",
    "expo-network": "~8.0.8",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.9",
    "firebase": "^12.13.0",
    "i18n-js": "^4.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^10.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.1.0",
    "@types/three": "^0.184.1",
    "babel-preset-expo": "~54.0.0",
    "eas-cli": "20.0.0",
    "tsx": "^4.19.4",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "searchPaths": [
        "../../node_modules",
        "./node_modules"
      ]
    }
  }
}
