# Expo (`apps/mobile`) — EXPO_PUBLIC_* ships to clients

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# OAuth Redirect Scheme (deep link)
EXPO_PUBLIC_AUTH_REDIRECT_SCHEME=com.yakrav7700.usriskcalc

# Next.js API (O-RADS AI proxy, Telegram bridge, auth CAPTCHA)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Cloudflare Turnstile site key (same as web NEXT_PUBLIC_TURNSTILE_SITE_KEY)
EXPO_PUBLIC_TURNSTILE_SITE_KEY=

# Chat/Telegram auth server (apps/mobile/server)
EXPO_PUBLIC_CHAT_API_URL=http://localhost:3100

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Remote Config эластографии (cut-off, шкалы, интерпретации)
EXPO_PUBLIC_ELASTOGRAPHY_CONFIG_URL=https://api.yourapp.com/v1/elastography-config.json
EXPO_PUBLIC_ELASTOGRAPHY_UPDATE_INTERVAL_HOURS=24
EXPO_PUBLIC_ELASTOGRAPHY_REQUEST_TIMEOUT_MS=10000
# true — локальный asset; false — всегда сеть (даже в __DEV__)
EXPO_PUBLIC_ELASTOGRAPHY_USE_LOCAL=true
