# Monorepo environment template (aggregate)

Copy variables into `apps/web/.env.local`, Vercel, Expo EAS secrets, and GitHub Actions.

```
# --- Shared Supabase ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe -------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO_MONTHLY=

# --- Web (local dev only — never on Vercel production) ------------------------
DEV_SKIP_AUTH=false
DEV_AUTO_LOGIN=false

# --- Web ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (Telegram / OAuth client ids for UI) -------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=sonogyn_bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=sonogyn_bot
NEXT_PUBLIC_VK_CLIENT_ID=
NEXT_PUBLIC_YANDEX_CLIENT_ID=
SONOGYN_AUTH_INTERNAL_SECRET=
# Random string ≥32 chars in production (server-to-server Telegram bridge)
EXPO_PUBLIC_AUTH_REDIRECT_SCHEME=com.yakrav7700.usriskcalc

# --- Cloudflare Turnstile (CAPTCHA после 3 неудачных попыток) ---------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Firebase (Analytics) ----------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Rate limiting (production) -----------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# AUTH_RATE_LIMIT_RELAXED=true   # staging only
# BOT_DETECTION_ENABLED=false    # default: block scrapers on /api/*
# RATE_LIMIT_AUTH_SIGN_IN=20
# RATE_LIMIT_AUTH_SIGN_IN_WINDOW_SEC=900
# RATE_LIMIT_PATIENTS_SEARCH=120
# RATE_LIMIT_PATIENTS_SEARCH_PER_USER=60
# RATE_LIMIT_AI_ORADS_BURST=5

OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_ORADS_MODEL=openai/gpt-4o-mini

# --- Observability ------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
```
