{
  "expo": {
    "name": "SonoGyn Pro",
    "slug": "us-risk-calc",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yakrav7700.usriskcalc",
      "buildNumber": "4",
      "infoPlist": {
        "NSCameraUsageDescription": "Камера: съёмка снимков для разделов AI и чата врачей.",
        "NSPhotoLibraryUsageDescription": "Галерея: выбор изображений для AI и чата.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.yakrav7700.usriskcalc",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Доступ к фото для загрузки изображений в приложение.",
          "cameraPermission": "Доступ к камере для съёмки изображений."
        }
      ],
      "expo-localization",
      "expo-asset"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "SonoGyn Pro",
      "shortName": "SonoGyn",
      "lang": "ru",
      "themeColor": "#005CB9",
      "backgroundColor": "#F8FBFF"
    },
    "extra": {
      "eas": {
        "projectId": "7a563271-84bd-4439-9b8b-e911adce3a44"
      }
    },
    "owner": "yakrav7700",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7a563271-84bd-4439-9b8b-e911adce3a44"
    }
  }
}
